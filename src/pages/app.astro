---
// Telegram Mini App — hosted at save.smoservice.media/app
// Pure HTML+JS, no backend calls. UI shortcuts that open bot commands.
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>SaveFastVideo</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
      :root {
        --bg: #0a0a0a;
        --card: #141414;
        --border: #222;
        --text: #f0f0f0;
        --muted: #888;
        --accent: #f97316;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        padding: 0 16px env(safe-area-inset-bottom, 16px);
        font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", system-ui, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.5;
        -webkit-tap-highlight-color: transparent;
      }
      header {
        padding: 24px 0 8px;
        text-align: center;
      }
      header .logo {
        font-size: 28px;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      header .logo span { color: var(--accent); }
      header p {
        margin: 6px 0 0;
        color: var(--muted);
        font-size: 14px;
      }
      h2 {
        font-size: 16px;
        margin: 24px 0 10px;
        color: var(--muted);
        font-weight: 500;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .actions { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
      .action {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 18px 14px;
        text-align: left;
        cursor: pointer;
        transition: transform .12s, background .12s;
        color: var(--text);
        font: inherit;
      }
      .action:active { transform: scale(0.96); background: #1a1a1a; }
      .action .emoji { font-size: 28px; display: block; margin-bottom: 8px; }
      .action .title { font-weight: 600; font-size: 15px; }
      .action .sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
      .platforms {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 8px;
      }
      .platform {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 14px 6px;
        text-align: center;
        font-size: 12px;
      }
      .platform .emoji { font-size: 24px; display: block; margin-bottom: 4px; }
      .hint {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 14px 16px;
        margin-top: 12px;
        font-size: 14px;
        line-height: 1.45;
      }
      .hint code {
        background: #1f1f1f;
        padding: 1px 6px;
        border-radius: 4px;
        font-size: 13px;
      }
      footer {
        margin-top: 28px;
        text-align: center;
        color: var(--muted);
        font-size: 12px;
        padding-bottom: 24px;
      }
      footer a { color: var(--muted); text-decoration: underline; }
    </style>
  </head>
  <body>
    <header>
      <div class="logo"><span>▶</span> SaveFastVideo</div>
      <p>Скачивание видео из соцсетей</p>
    </header>

    <h2>Что хочешь сделать</h2>
    <div class="actions">
      <button class="action" data-action="download">
        <span class="emoji">📥</span>
        <div class="title">Скачать видео</div>
        <div class="sub">Просто пришли ссылку</div>
      </button>
      <button class="action" data-action="transcript">
        <span class="emoji">🎙</span>
        <div class="title">Видео в текст</div>
        <div class="sub">Распознать речь</div>
      </button>
      <button class="action" data-action="subscribe">
        <span class="emoji">🔔</span>
        <div class="title">Подписки</div>
        <div class="sub">VK / YouTube каналы</div>
      </button>
      <button class="action" data-action="quality">
        <span class="emoji">🎛</span>
        <div class="title">Качество</div>
        <div class="sub">1080p / 720p / MP3</div>
      </button>
    </div>

    <h2>Поддерживаемые платформы</h2>
    <div class="platforms">
      <div class="platform"><span class="emoji">🟣</span>Instagram</div>
      <div class="platform"><span class="emoji">⚫</span>TikTok</div>
      <div class="platform"><span class="emoji">🔴</span>YouTube</div>
      <div class="platform"><span class="emoji">✖️</span>X / Twitter</div>
      <div class="platform"><span class="emoji">🔵</span>VK</div>
      <div class="platform"><span class="emoji">🧡</span>OK</div>
    </div>

    <div id="hint" class="hint" style="display:none"></div>

    <footer>
      <a href="https://t.me/SaveFastVideoFreebot">@SaveFastVideoFreebot</a>
      ·
      <a href="/">Сайт</a>
    </footer>

    <script is:inline>
      (function () {
        const tg = window.Telegram && window.Telegram.WebApp;
        const inTelegram = !!tg && tg.initData !== undefined && tg.initData !== '';
        if (tg) {
          try {
            tg.ready();
            tg.expand();
            // theme
            const tp = tg.themeParams || {};
            if (tp.bg_color) document.documentElement.style.setProperty('--bg', tp.bg_color);
            if (tp.secondary_bg_color) document.documentElement.style.setProperty('--card', tp.secondary_bg_color);
            if (tp.text_color) document.documentElement.style.setProperty('--text', tp.text_color);
            if (tp.hint_color) document.documentElement.style.setProperty('--muted', tp.hint_color);
            if (tp.button_color) document.documentElement.style.setProperty('--accent', tp.button_color);
          } catch (e) {}
        }

        const hints = {
          download:   '📥 <b>Скачать видео</b><br/>Просто отправь ссылку на видео из Instagram / TikTok / YouTube в чат с ботом. Можно с <code>https://</code> и без — бот сам определит платформу.',
          transcript: '🎙 <b>Транскрипция видео в текст</b><br/>Отправь ссылку на видео обычным сообщением, а потом ответом на это сообщение — команду <code>/transcript</code>. Бот распознает речь (поддержка ru / en / 40+ языков) и пришлёт текст.',
          subscribe:  '🔔 <b>Подписки на каналы</b><br/>Команда:<br/><code>/subscribe https://youtube.com/@MrBeast</code><br/>Бот будет автоматически присылать новые видео каждые 30 минут. Платформы: <b>YouTube</b> и <b>VK</b>. Список подписок: <code>/subscriptions</code>',
          quality:    '🎛 <b>Выбор качества</b><br/>В чате с ботом нажми <b>Меню</b> (под полем ввода) → <b>🎛 Качество</b> → выбери 1080p, 720p, 480p или 🎵 Только звук (mp3). Качество сохранится для всех будущих скачиваний.',
        };

        const hintEl = document.getElementById('hint');
        document.querySelectorAll('.action').forEach(btn => {
          btn.addEventListener('click', () => {
            const action = btn.getAttribute('data-action');
            // haptic if in TG
            if (inTelegram && tg.HapticFeedback) {
              try { tg.HapticFeedback.impactOccurred('light'); } catch (e) {}
            }
            hintEl.innerHTML = hints[action] || '';
            hintEl.style.display = 'block';
            // show MainButton to close the mini app
            if (inTelegram && tg.MainButton) {
              try {
                tg.MainButton.setText('Назад в бот');
                tg.MainButton.show();
                tg.MainButton.onClick(() => tg.close());
              } catch (e) {}
            }
            hintEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          });
        });

        // BackButton support
        if (inTelegram && tg.BackButton) {
          try {
            tg.BackButton.onClick(() => tg.close());
            tg.BackButton.show();
          } catch (e) {}
        }
      })();
    </script>
  </body>
</html>
